# Copy to secrets.yaml (same folder) and fill in the values.
# Do not commit secrets.yaml.

wifi_ssid: "YOUR_WIFI"
wifi_password: "YOUR_PASSWORD"

# openssl rand -base64 32
api_encryption_key: "GENERATE_AND_FILL_IN"

ota_password: "SECURE_OTA_PASSWORD"

# Optional: MQTT output of the IR meter for a Venus OS / Cerbo GX bridge.
mqtt_broker: "192.168.1.10"
mqtt_username: "MQTT_USER"
mqtt_password: "MQTT_PASSWORD"
