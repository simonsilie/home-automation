# Kopiere nach secrets.yaml (gleicher Ordner) und Werte eintragen.
# secrets.yaml nicht versionieren.

wifi_ssid: "DEIN_WLAN"
wifi_password: "DEIN_PASSWORT"

# openssl rand -base64 32
api_encryption_key: "GENERIEREN_UND_EINTRAGEN"

ota_password: "SICHERES_OTA_PASSWORT"

# Optional: MQTT-Ausgabe des IR-Zählers für eine Venus OS / Cerbo GX Bridge.
mqtt_broker: "192.168.1.10"
mqtt_username: "MQTT_USER"
mqtt_password: "MQTT_PASSWORT"
